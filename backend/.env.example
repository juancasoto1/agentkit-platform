# AgentKit Platform — Variables de entorno
# Copiar a .env y llenar con tus valores

# === API Keys ===
ANTHROPIC_API_KEY=sk-ant-...

# === Base de datos ===
DATABASE_URL=postgresql+asyncpg://user:password@localhost/agentkit_db
DATABASE_URL_SYNC=postgresql://user:password@localhost/agentkit_db

# === JWT ===
SECRET_KEY=tu-clave-secreta-muy-larga-aqui-cambia-esto
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# === Servidor ===
PORT=8000
ENVIRONMENT=development

# === WhatsApp Providers ===
WHATSAPP_PROVIDER=meta  # meta | twilio

# Meta Cloud API
META_ACCESS_TOKEN=your-meta-token
META_PHONE_NUMBER_ID=your-phone-id
META_VERIFY_TOKEN=agentkit-verify-token

# Twilio
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# === Integraciones ===
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SHOP_NAME=

# === Email (Resend) ===
RESEND_API_KEY=

# === Redis (opcional) ===
REDIS_URL=redis://localhost:6379

# === Sentry (opcional) ===
SENTRY_DSN=
